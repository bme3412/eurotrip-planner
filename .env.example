# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to version control
#
# Key rotation dashboards:
#   Supabase: https://supabase.com/dashboard → Project Settings → API
#   OpenAI:   https://platform.openai.com/api-keys
#   Mapbox:   https://account.mapbox.com/access-tokens/

# ── Required ────────────────────────────────────────────────────────

# Mapbox (public token for map rendering)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiYm1lMzQxMiIsImEiOiJjbWRreXc0bzQxNHpwMm1wemoybnc2NzV5In0.MHyaJYT5oo7HgQB1Sobsuw

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI (used server-side for AI itinerary generation)
OPENAI_API_KEY=your_openai_key_here

# Anthropic (used for conversational trip planner)
# Get key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Places API (New) — for live attraction data, photos, reviews
# Get key at: https://console.cloud.google.com/apis/credentials
# Enable: Places API (New), Places Photos API
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# Google Routes API — optional, for travel-time-based itinerary stop ordering
# If omitted, the app falls back to GOOGLE_PLACES_API_KEY, then static proximity routing.
GOOGLE_ROUTES_API_KEY=your_google_routes_key_here

# Google Gemini API — optional, reserved for preference interpretation/summaries.
# Not used for choosing AI picks in city guide Experiences.
GEMINI_API_KEY=your_gemini_key_here

# ── Optional ────────────────────────────────────────────────────────

# OpenAI model override (defaults to gpt-4.1-mini)
# OPENAI_MODEL=gpt-4.1-mini

# Amazon Bedrock (optional — for /api/plan/agent-bedrock, Phase 1 Converse API)
# Enable model access in Bedrock console, then set:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-v2:0
# Agent provider: "openai" (default), "bedrock-converse", or "bedrock-agent"
# NEXT_PUBLIC_AGENT_PROVIDER=openai

# Bedrock Agent (Phase 2+): set after creating agent in Bedrock console
# BEDROCK_AGENT_ID=your_agent_id
# BEDROCK_AGENT_ALIAS_ID=your_alias_id

# CDN base URL (CloudFront). Omit to serve assets locally.
# NEXT_PUBLIC_CDN_URL=https://your-cdn-domain.cloudfront.net

# Set to "true" to run @next/bundle-analyzer during build
# ANALYZE=true

# ── Affiliate Partner IDs (optional — features work without them) ──
# NEXT_PUBLIC_GYG_PARTNER_ID=
# NEXT_PUBLIC_VIATOR_PARTNER_ID=
# NEXT_PUBLIC_BOOKING_AID=
