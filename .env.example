# Copy to .env.local and fill in values.

# Google Places (photos + itinerary enrichment)
GOOGLE_PLACES_API_KEY=

# Claude — planner agent, concierge generation, scoring prose
ANTHROPIC_API_KEY=

# Mapbox (maps)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase (auth + trips + concierge persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: force OAuth redirect origin in non-local deploys
NEXT_PUBLIC_AUTH_REDIRECT_ORIGIN=

# Concierge — Inngest scheduling (local dev: INNGEST_DEV=1 instead)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=

# Concierge — Web Push (generate: node -e "console.log(require('web-push').generateVAPIDKeys())")
VAPID_SUBJECT=mailto:you@yourdomain.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Concierge — email + reactive weather
RESEND_API_KEY=
FROM_EMAIL=Olivier <briefing@yourdomain.com>
OPENWEATHERMAP_API_KEY=

# Optional but recommended in production: suggestions cache, brief cache, anonymous API rate limits
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NEXT_PUBLIC_CDN_URL=

# Optional: itinerary feature flags
ITINERARY_CLOCK_TIMES=true
ITINERARY_LLM_CURATE=false
ITINERARY_PLACES_FALLBACK=false

# Optional: swap agent model
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
