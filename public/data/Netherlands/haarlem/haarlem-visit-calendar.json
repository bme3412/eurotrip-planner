    "3": "Average: Standard conditions, typical weather, moderate to high tourism",
    "4": "Good: Very favorable conditions, pleasant weather, manageable crowds",
    "5": "Excellent: Perfect conditions, special events, ideal weather, moderate crowds"
  }
}