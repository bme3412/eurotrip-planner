# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# weather backfill runtime artifacts
scripts/.weather_checkpoint.json
scripts/.weather-backfill.log
scripts/.weather-backfill.launchd.log

# env files
.env
.env.local
.env.*.local
.env.development
.env.production
!.env.example

# vercel
.vercel

# supabase CLI local state
supabase/.temp/

# generated files (rebuilt during build)
src/generated/
public/calendars/

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code local state
.claude/worktrees/
.claude/scheduled_tasks.lock
