# Copy to .env.local and fill in values.

# Google Places (photos + itinerary enrichment)
GOOGLE_PLACES_API_KEY=

# Claude — planner agent, concierge generation, scoring prose
ANTHROPIC_API_KEY=

# Mapbox (maps)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase (auth + trips + concierge persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: force OAuth redirect origin in non-local deploys
NEXT_PUBLIC_AUTH_REDIRECT_ORIGIN=

# Concierge — Inngest scheduling (local dev: INNGEST_DEV=1 instead)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=

# Concierge — Web Push (generate: node -e "console.log(require('web-push').generateVAPIDKeys())")
VAPID_SUBJECT=mailto:you@yourdomain.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Concierge — email + reactive weather
RESEND_API_KEY=
FROM_EMAIL=Olivier <briefing@yourdomain.com>
OPENWEATHERMAP_API_KEY=

# Concierge — closed beta gate. Comma-separated emails that are always invited
# (operator escape hatch); everyone else needs an invited concierge_waitlist
# row (flip with: node --env-file=.env.local scripts/concierge-invite.mjs <email>).
CONCIERGE_ALLOWLIST=
# Where waitlist-signup notifications go (optional; needs RESEND_API_KEY)
CONCIERGE_OPERATOR_EMAIL=
# Signs one-click unsubscribe links in brief emails (falls back to
# SUPABASE_SERVICE_ROLE_KEY when unset)
CONCIERGE_UNSUBSCRIBE_SECRET=

# Telegram channel (optional). Create a bot via @BotFather, then run
# scripts/telegram-setup.mjs to register the webhook + get the username.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Signs Telegram account-link codes (falls back to SUPABASE_SERVICE_ROLE_KEY)
CONCIERGE_LINK_SECRET=
# Absolute origin used in emails (unsubscribe + invite links)
NEXT_PUBLIC_SITE_URL=https://eurotrip-planner.vercel.app

# Optional but recommended in production: suggestions cache, brief cache, API rate limits
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NEXT_PUBLIC_CDN_URL=

# Optional: bearer token for /api/admin/refresh (dev-only route). When unset,
# the route only accepts requests from localhost.
ADMIN_REFRESH_TOKEN=

# Optional: itinerary feature flags
ITINERARY_CLOCK_TIMES=true
ITINERARY_LLM_CURATE=false
ITINERARY_PLACES_FALLBACK=false
ITINERARY_LLM_ENRICH=true

# Optional: swap agent model
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional: walking/transit times (falls back to GOOGLE_PLACES_API_KEY)
GOOGLE_ROUTES_API_KEY=

# Optional: affiliate partner ids (links render unaffiliated when unset)
NEXT_PUBLIC_BOOKING_AID=
NEXT_PUBLIC_GYG_PARTNER_ID=
NEXT_PUBLIC_VIATOR_PARTNER_ID=

# Optional, build/refresh scripts only
# REFRESH_OVERVIEW_MODEL= (model for scripts/refresh overview generation)
# EUROTRIP_INDEX_INCLUDE_MONTHLY=false (drop monthly data from index.json, ~35% smaller)
# DEBUG=1 (verbose output from scripts/refresh)
